# UploadThing Configuration
# Get your token from https://uploadthing.com/dashboard (API Keys > V7 tab)
UPLOADTHING_TOKEN=

# Server Configuration
HOST=127.0.0.1
PORT=3000
NODE_ENV=development

# MCP Metadata
MCP_TITLE=UploadThing MCP Server
MCP_INSTRUCTIONS=Use these tools to upload, list, and manage files on UploadThing.
MCP_VERSION=1.0.0

# Auth Strategy
AUTH_STRATEGY=none

# Logging
LOG_LEVEL=info
